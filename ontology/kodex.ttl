kodex:Role_Collator
    a kodex:RoleType , skos:Concept ;
    skos:inScheme kodex:RoleTypeScheme ;
    skos:prefLabel "교감자"@ko , "校勘者"@zh , "Collator"@en ;
    skos:note "MARC Relator에 대응 항목 없음. KoDEX 확장 정의."@ko .

kodex:Role_Publisher
    a kodex:RoleType , skos:Concept ;
    skos:inScheme kodex:RoleTypeScheme ;
    skos:prefLabel "간행자"@ko , "刊行者"@zh , "Publisher"@en ;
