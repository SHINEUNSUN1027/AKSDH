# 판본: 1820년 내각 목판본
<https://w3id.org/kodex/edition/LNJ-1820-Mokpan>
    a kodex:Edition ;
    bf:instanceOf        <https://w3id.org/kodex/work/LNJ> ;
    kodex:hasEditionType kodex:MokpanBon ;
    bf:provisionActivity [
        a bf:Publication ;
        bf:agent <https://w3id.org/kodex/org/Naegak> ;
        bf:place <https://w3id.org/kodex/place/Hanseong> ;
        bf:date  "1820"^^xsd:gYear
    ] ;
    skos:note "刊記: 庚辰(1820)新刊內閣藏板"@zh .

